# Copy to .env and fill in. .env is gitignored; never commit real values.

# Supabase CLI (server-side; used by `supabase db push`). The DB password you
# set when creating the project.
SUPABASE_DB_PASSWORD=

# Frontend (Vite, client-side). The anon/publishable key is public by design —
# RLS + Edge Functions are the security boundary, not the key.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
